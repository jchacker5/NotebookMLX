## Backend configuration
# Host and port for FastAPI
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Comma-separated list of allowed origins for CORS.
# Include 'null' for Electron file:// origin and 'app://.' for packaged app scheme.
ALLOWED_ORIGINS=http://localhost:3000,null,app://.
ALLOW_CREDENTIALS=true

## Model configuration (optional overrides)
# PDF_PREPROCESS_MODEL=mlx-community/Qwen2.5-1.5B-Instruct-4bit
# TRANSCRIPT_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit
# REWRITER_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit

