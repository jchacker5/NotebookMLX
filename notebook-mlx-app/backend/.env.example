# NotebookMLX Backend Configuration

# Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DATA_DIR=data

# Security Configuration (PRODUCTION: Remove null and app://.)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOW_CREDENTIALS=true
SECRET_KEY=your-secret-key-here-change-in-production

# File Upload Limits
BACKEND_MAX_UPLOAD_MB=200
BACKEND_MAX_CHUNK_MB=16
BACKEND_MAX_TOTAL_MB=400
MAX_DOWNLOAD_SIZE_MB=100

# Rate Limiting
EXPORT_RATE_LIMIT_PER_MIN=60
GEN_CONCURRENCY=2

# ML Configuration
DISABLE_ML_IMPORTS=0
DEFAULT_MODEL_TYPE=qwen3-8b
FORCE_CPU_MODE=0

# Database Configuration (Production: use PostgreSQL)
DATABASE_URL=sqlite:///data/notebookmlx.db
# DATABASE_URL=postgresql://user:password@localhost/notebookmlx

# Monitoring & Logging
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
SENTRY_DSN=your-sentry-dsn-here

# TTS Configuration
TTS_CONCURRENT_REQUESTS=1
TTS_TIMEOUT_SECONDS=300

# Voice Training
VOICE_TRAINING_ENABLED=true
MAX_VOICE_SAMPLES=10

# External Services
OPENAI_API_KEY=your-openai-key-if-needed
HUGGINGFACE_TOKEN=your-hf-token-if-needed

# Legacy Model Configuration (optional overrides)
# PDF_PREPROCESS_MODEL=mlx-community/Qwen2.5-1.5B-Instruct-4bit
# TRANSCRIPT_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit
# REWRITER_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
